#!/usr/bin/env python3

import os
import random
import string
import time

def display_banner():
    print(r"""
=========================
      NightLord
=========================
""")

def random_string(length=50):
    return ''.join(random.choices(string.ascii_letters + string.digits, k=length))

def create_edit_delete():
    folder = "NightLord"
    os.makedirs(folder, exist_ok=True)

    while True:
        try:
            filename = os.path.join(folder, random_string(8) + ".txt")

            # Create
            with open(filename, "w") as f:
                for _ in range(20):
                    f.write(random_string() + "\n")
            print(f"[+] Created: {filename}")

            time.sleep(2)

            # Edit
            with open(filename, "a") as f:
                f.write("\nEdited by NightLord\n")
            print(f"[*] Edited: {filename}")

            time.sleep(1)

            # Delete
            os.remove(filename)
            print(f"[-] Deleted: {filename}")

            time.sleep(1)

        except Exception as e:
            print("Error:", e)
            break

if __name__ == "__main__":
    display_banner()
    create_edit_delete()
