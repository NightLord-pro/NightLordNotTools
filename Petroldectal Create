# Helper Print Functions
print_header() {
    echo -e "\n${PURPLE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN} ⚔️ $1 ⚔️ ${NC}"
    echo -e "${PURPLE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
}

print_status() {
    echo -e "${YELLOW}⏳ [NightLord System]: $1...${NC}"
}

print_success() {
    echo -e "${GREEN}✅ [System Success]: $1${NC}"
}

print_error() {
    echo -e "${RED}❌ [Gate Error]: $1${NC}"
}

confirm_action() {
    local message="$1"
    echo -e "${YELLOW}$message${NC}"
    read -p "$(echo -e "${PURPLE}Are you sure you wish to proceed, My Monarch? (y/N): ${NC}")" -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${GREEN}Operation cancelled by Monarch decree.${NC}"
        return 1
    fi
    return 0
}

# ================== 1. INSTALL FUNCTION ==================
install_ptero() {
    clear
    echo -e "${PURPLE}"
    echo "┌──────────────────────────────────────────────┐"
    echo "│     🚀 Pterodactyl Installation (Monarch)    │"
    echo "└──────────────────────────────────────────────┘${NC}"
    
    bash <(curl -s https://raw.githubusercontent.com/nobita329/The-Coding-Hub/refs/heads/main/srv/panel/pterodactyl.sh)
    
    echo -e "${GREEN}✔ Gate Installation Complete, My Monarch${NC}"
    read -p "$(echo -e "${PURPLE}Press Enter to return to the Shadow Throne...${NC}")"
}

# ================== 2. CREATE USER FUNCTION ==================
create_user() {
    clear
    echo -e "${PURPLE}"
    echo "┌──────────────────────────────────────────────┐"
    echo "│     👤 Create Pterodactyl Monarch User       │"
    echo "└──────────────────────────────────────────────┘${NC}"

    if [ ! -d /var/www/pterodactyl ]; then
        echo -e "${RED}❌ Gate Error: Panel sanctuary not installed!${NC}"
        read -p "Press Enter to return..."
        return
    fi

    cd /var/www/pterodactyl || exit
    php artisan p:user:make

    echo -e "${GREEN}✔ Sovereign User forged successfully${NC}"
    read -p "$(echo -e "${PURPLE}Press Enter to return...${NC}")"
}

# ================== 3. UPDATE FUNCTION ==================
update_panel() {
    clear
    echo -e "${PURPLE}"
    echo "═══════════════════════════════════════════════"
    echo "       ⚡ PTERODACTYL PANEL UPGRADE ⚡          "
    echo "═══════════════════════════════════════════════${NC}"

    if [ "$EUID" -ne 0 ]; then
        print_error "Please run this script as root or with sudo, My Monarch!"
        read -p "Press Enter to return..."
        return
    fi

    cd /var/www/pterodactyl || {
        echo -e "${RED}❌ Gate Error: Panel sanctuary not found at /var/www/pterodactyl!${NC}"
        read -p "Press Enter to return..."
        return
    }

    print_status "Putting panel into maintenance mode"
    php artisan down > /dev/null 2>&1 || true

    print_status "Downloading latest Panel release matrix"
    curl -L https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz | tar -xzv > /dev/null 2>&1

    print_status "Setting correct storage permissions"
    chmod -R 755 storage/* bootstrap/cache > /dev/null 2>&1

    print_status "Synchronizing composer dependencies"
    composer install --no-dev --optimize-autoloader > /dev/null 2>&1

    print_status "Clearing system caches"
    php artisan view:clear > /dev/null 2>&1
    php artisan config:clear > /dev/null 2>&1

    print_status "Running database migrations"
    php artisan migrate --seed --force > /dev/null 2>&1

    print_status "Securing file ownership"
    chown -R www-data:www-data /var/www/pterodactyl/* > /dev/null 2>&1

    print_status "Restarting queue workers"
    php artisan queue:restart > /dev/null 2>&1

    print_status "Bringing panel back online"
    php artisan up > /dev/null 2>&1

    echo -e "${GREEN}🎉 Panel Upgraded Successfully, Monarch!${NC}"
    read -p "$(echo -e "${PURPLE}Press Enter to return...${NC}")"
}

# ================== 4. UNINSTALL FUNCTIONS ==================
cleanup_nginx() {
    print_status "Banish Nginx configurations for Pterodactyl"
    
    if [[ -f "/etc/nginx/sites-enabled/pterodactyl.conf" ]]; then
        sudo rm -f /etc/nginx/sites-enabled/pterodactyl.conf
    fi
    if [[ -f "/etc/nginx/sites-available/pterodactyl.conf" ]]; then
        sudo rm -f /etc/nginx/sites-available/pterodactyl.conf
    fi
    if [[ -f "/etc/nginx/conf.d/pterodactyl.conf" ]]; then
        sudo rm -f /etc/nginx/conf.d/pterodactyl.conf
    fi

    if command -v nginx >/dev/null 2>&1; then
        sudo systemctl restart nginx
        print_success "Nginx reloaded and cleansed"
    fi
}

uninstall_panel() {
    print_header "PURGING PTERODACTYL PANEL"
    
    if ! confirm_action "This will completely eradicate the Pterodactyl Panel and all its data matrix."; then
        return
    fi

    print_status "Halting Panel service"
    sudo systemctl stop pteroq.service 2>/dev/null || true
    sudo systemctl disable pteroq.service 2>/dev/null || true
    sudo rm -f /etc/systemd/system/pteroq.service
    sudo systemctl daemon-reload

    print_status "Erasing Panel cronjob"
    sudo crontab -l | grep -v 'php /var/www/pterodactyl/artisan schedule:run' | sudo crontab - 2>/dev/null || true

    print_status "Obliterating Panel files"
    sudo rm -rf /var/www/pterodactyl

    print_status "Eradicating Panel MySQL database and user"
    sudo mysql -u root -e "DROP DATABASE IF EXISTS panel;" 2>/dev/null || true
    sudo mysql -u root -e "DROP USER IF EXISTS 'pterodactyl'@'127.0.0.1';" 2>/dev/null || true
    sudo mysql -u root -e "FLUSH PRIVILEGES;" 2>/dev/null || true

    cleanup_nginx

    print_success "Panel uninstalled successfully, My Monarch!"
}

uninstall_wings() {
    print_header "PURGING PTERODACTYL WINGS"
    
    if ! confirm_action "This will remove Wings and all associated daemon nodes."; then
        return
    fi

    print_status "Halting Wings service"
    sudo systemctl stop wings.service 2>/dev/null || true
    sudo systemctl disable wings.service 2>/dev/null || true
    sudo rm -f /etc/systemd/system/wings.service
    sudo systemctl daemon-reload

    print_status "Removing Wings files"
    sudo rm -rf /etc/pterodactyl
    sudo rm -rf /var/lib/pterodactyl
    sudo rm -rf /var/log/pterodactyl
    sudo rm -f /usr/local/bin/wings
    sudo rm -f /usr/local/bin/wing

    print_success "Wings uninstalled successfully, Monarch!"
}

uninstall_both() {
    print_header "PURGING BOTH PANEL AND WINGS"
    
    if ! confirm_action "This will eradicate both Pterodactyl Panel and Wings completely from the server realm."; then
        return
    fi

    uninstall_panel
    uninstall_wings
    
    print_success "Panel and Wings completely obliterated together, My Monarch!"
}

