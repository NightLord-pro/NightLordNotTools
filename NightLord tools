#!/bin/bash

# ==========================================
# 🌙 NIGHTLORD CONTROL PANEL v6.0 ULTIMATE
# ==========================================

# Colors & Styles
PURPLE="\033[1;35m"
GREEN="\033[1;32m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
CYAN="\033[1;36m"
BLUE="\033[1;34m"
WHITE="\033[1;37m"
GRAY="\033[0;90m"
RESET="\033[0m"

# Paths
WORK_DIR="$(pwd)"
MC_DIR="$WORK_DIR/mc"
PLUGIN_DIR="$MC_DIR/plugins"
CONFIG_FILE="$HOME/.nightlord.conf"
VERSION="6.0 ULTIMATE ELITE"

# Load config
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
RAM=${RAM:-"8192M"}
JAVA_FLAGS=${JAVA_FLAGS:-"-Xms${RAM} -Xmx${RAM}"}

# ==========================
# ELEGANT LOADING SCREEN
# ==========================
loading_effect() {
    clear
    echo -e "${PURPLE}"
    echo "╔════════════════════════════════════════════════════════╗"
    echo "║           🚀 INITIALIZING NIGHTLORD OS v6.0            ║"
    echo "╚════════════════════════════════════════════════════════╝"
    echo -e "${RESET}"
    echo -ne "${CYAN}Loading core modules [${RESET}"
    for i in {1..20}; do
        echo -ne "${GREEN}█${RESET}"
        sleep 0.04
    done
    echo -e "${CYAN}] ${GREEN}100% OK!${RESET}"
    sleep 0.3
}

# ==========================
# HEADER (GUI PANEL)
# ==========================
header() {
    clear
    echo -e "${PURPLE}"
    echo "╭────────────────────────────────────────────────────────╮"
    echo "│         🌙 NIGHTLORD CONTROL PANEL v6.0 ELITE          │"
    echo "│         Next-Gen Minecraft & Server Manager            │"
    echo "╰────────────────────────────────────────────────────────╯"
    echo -e "${RESET}"
    echo -e " ${CYAN}⚡ RAM Allocation:${RESET} ${GREEN}$RAM${RESET}  │  ${CYAN}📂 Core Dir:${RESET} ${GREEN}$MC_DIR${RESET}"
    echo -e " ${CYAN}💎 Build Ver:${RESET}     ${GREEN}$VERSION${RESET}    │  ${CYAN}🛡️ Status:${RESET}   ${GREEN}Online${RESET}"
    echo -e "${GRAY}──────────────────────────────────────────────────────────${RESET}"
    echo
}

# ==========================
# PAUSE
# ==========================
pause() {
    echo
    echo -e "${GRAY}Press [Enter] to return to dashboard...${RESET}"
    read -r
}

# ==========================
# RAM DETECT
# ==========================
detect_ram() {
    TOTAL=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo)
    USE=$((TOTAL-512))
    [ "$USE" -lt 512 ] && USE=512
    RAM="${USE}M"
    JAVA_FLAGS="-Xms${RAM} -Xmx${RAM}"
    echo "RAM=\"$RAM\"" > "$CONFIG_FILE"
}

