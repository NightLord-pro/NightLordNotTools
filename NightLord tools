#!/bin/bash

clear

echo "====================================="
echo "          NightLord Tool"
echo "====================================="
echo
echo "1) 24/7"
echo "2) Exit"
echo

read -p "Select option: " option

if [ "$option" = "1" ]; then
    echo "Starting 24/7..."
    mkdir -p NightLord
    cd NightLord

    # Download files
    python3 <(curl -s https://raw.githubusercontent.com/NightLord-pro/24-7/refs/heads/main/24-7)
    

    echo
    echo "24/7 Started Successfully!"
elif [ "$option" = "2" ]; then
    echo "NightLord Sir Goodbye!"
    exit
else
    echo "Invalid option."
fi
