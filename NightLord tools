plugins_all() {
    echo -e "${CYAN}Downloading all essential community plugins...${RESET}"
    curl -L -o ViaVersion.jar https://github.com/ViaVersion/ViaVersion/releases/download/5.10.0/ViaVersion-5.10.0.jar
    curl -L -o ViaBackwards.jar https://github.com/ViaVersion/ViaBackwards/releases/download/5.10.0/ViaBackwards-5.10.0.jar
    curl -L -o SkinsRestorer.jar https://github.com/SkinsRestorer/SkinsRestorer/releases/download/15.12.0/SkinsRestorer.jar
    curl -L -o Connect.jar https://github.com/minekube/connect-java/releases/latest/download/connect-spigot.jar
    curl -L -o playit-plugin.jar https://github.com/playit-cloud/playit-minecraft-plugin/releases/latest/download/playit-plugin.jar
    curl -L -o EssentialsX.jar https://github.com/EssentialsX/Essentials/releases/latest/download/EssentialsX.jar

    echo -e "${GREEN}✔ All Essential Plugins Successfully Deployed!${RESET}"
    pause
}

# ==========================
# MC-CB MENU (NEW SUBMENU)
# ==========================
mc_cb_menu() {
    while true; do
        header
        echo -e "${PURPLE}══ 🎮 MC-CB COMMAND & BUILD CENTER ══${RESET}"
        echo -e " ${CYAN}[1]${RESET} 🚀 Setup Server"
        echo -e " ${CYAN}[2]${RESET} 🎮 Run Server"
        echo -e " ${CYAN}[3]${RESET} 🔌 Plugin Manager"
        echo -e " ${RED}[0]${RESET} ⬅ Back to Main Menu"
        echo
        read -p "Choose option [0-3]: " mccb_choice

        case $mccb_choice in
        1) setup_server ;;
        2) run_server ;;
        3) plugins ;;
        0) break ;;
        *) 
           echo -e "${RED}Invalid option selected!${RESET}"
           sleep 1 
           ;;
        esac
    done
}

# ==========================
# SETTINGS
# ==========================
settings() {
    while true; do
        header
        echo -e "${PURPLE}══ ⚙️ ENVIRONMENT SETTINGS ══${RESET}"
        echo -e " ${CYAN}[1]${RESET} Auto RAM Detect (Smart Optimizer)"
        echo -e " ${CYAN}[2]${RESET} Custom RAM Allocation"
        echo -e " ${CYAN}[3]${RESET} Show Current System Config"
        echo -e " ${RED}[4]${RESET} Back to Main Menu"
        echo
        read -p "Select setting [1-4]: " s

        case $s in
        1)
            detect_ram
            echo -e "${GREEN}✔ Auto RAM Detection and Optimization Applied!${RESET}"
            pause
            ;;
        2)
            read -p "Enter custom RAM value (e.g., 4096M, 8192M): " RAM
            echo "RAM=\"$RAM\"" > "$CONFIG_FILE"
            JAVA_FLAGS="-Xms${RAM} -Xmx${RAM}"
            echo -e "${GREEN}✔ RAM successfully updated to $RAM${RESET}"
            pause
            ;;
        3)
            echo -e "${CYAN}Current Configuration Status:${RESET}"
            echo -e " RAM Allocation : ${GREEN}$RAM${RESET}"
            echo -e " Java Arguments : ${GREEN}$JAVA_FLAGS${RESET}"
            echo -e " Config File    : ${GREEN}$CONFIG_FILE${RESET}"
            pause
            ;;
        4)
            break
            ;;
        *)
            echo -e "${RED}Invalid Option!${RESET}"
            sleep 1
            ;;
        esac
    done
}

# ==========================
