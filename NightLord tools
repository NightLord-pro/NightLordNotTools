#!/bin/bash

# ==========================
# NightLord Tools
# ==========================

# Colors
PURPLE="\e[35m"
BOLD="\e[1m"
RESET="\e[0m"

# Loading Animation
loading() {
    local msg="${1:-Loading}"
    local spin='|/-\'

    echo -ne "${PURPLE}${msg} ${RESET}"
    for i in {1..30}; do
        printf "\b${PURPLE}${spin:i%4:1}${RESET}"
        sleep 0.1
    done
    echo -e "\b${PURPLE}✔${RESET}"
}

while true; do
    clear

    echo -e "${PURPLE}${BOLD}"
    echo "=================================================="
    echo " _   _ _       _     _   _                     _ "
    echo "| \ | (_)     | |   | | | |                   | |"
    echo "|  \| |_  __ _| |__ | |_| |    ___  _ __   ___| |"
    echo "| . \` | |/ _\` | '_ \| __| |   / _ \| '_ \ / _ \ |"
    echo "| |\  | | (_| | | | | |_| |__| (_) | | | |  __/_|"
    echo "|_| \_|_|\__, |_| |_|\__|_____\___/|_| |_|\___(_)"
    echo "          __/ |                                  "
    echo "         |___/                                   "
    echo
    echo "              N I G H T L O R D   T O O L S"
    echo "=================================================="
    echo -e "${RESET}"

    echo -e "${PURPLE}1) 24/7${RESET}"
    echo -e "${PURPLE}2) Exit${RESET}"
    echo

    read -p "Select option: " option

    case "$option" in
        1)
            echo
            loading "Starting NightLord Tools"
            curl -fsSL "https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/24-7" | python3
            echo
            read -p "Press Enter to return to menu..."
            ;;
        2)
            echo
            echo -e "${PURPLE}NightLord Sir Goodbye!${RESET}"
            break
            ;;
        *)
            echo
            echo -e "${PURPLE}Invalid option!${RESET}"
            sleep 2
            ;;
    esac
done
