# ==========================
# SERVER SETUP
# ==========================
setup_server() {
    version_selector
    if [ $? -eq 1 ]; then
        return
    fi

    header
    mkdir -p "$MC_DIR"
    cd "$MC_DIR" || return

    echo -e "${CYAN}🚀 Downloading Selected Paper Server core...${RESET}"
    curl -L -o server.jar "$DOWNLOAD_URL"

    if [ $? -ne 0 ] || [ ! -s server.jar ]; then
        echo -e "${RED}❌ Download failed! Check connection or URL parameters.${RESET}"
        rm -f server.jar
        pause
        return
    fi

    echo "eula=true" > eula.txt
    mkdir -p plugins

    echo -e "${GREEN}✔ Server Core Installed & EULA Accepted Successfully!${RESET}"
    pause
}

# ==========================
# RUN SERVER
# ==========================
run_server() {
    header
    cd "$MC_DIR" || return

    if [ ! -f server.jar ]; then
        echo -e "${RED}❌ Server core not found! Please run 'Setup Server' first inside MC-CB menu.${RESET}"
        pause
        return
    fi

    echo -e "${GREEN}🎮 Launching Minecraft Server Engine...${RESET}"
    echo -e "${GRAY}Java Flags: $JAVA_FLAGS${RESET}"
    echo
    java $JAVA_FLAGS -jar server.jar nogui
    pause
}

# ==========================
# PLUGIN MANAGER
# ==========================
plugins() {
    while true; do
        header
        mkdir -p "$PLUGIN_DIR"
        cd "$PLUGIN_DIR" || return

        echo -e "${PURPLE}══ 🔌 PLUGIN MANAGER (Essentials for All Versions) ══${RESET}"
        echo -e " ${CYAN}[1]${RESET} ViaVersion"
        echo -e " ${CYAN}[2]${RESET} ViaBackwards"
