#!/bin/bash

# ==========================
# NightLord Tools
# ==========================

# Colors
PURPLE="\033[1;35m"
GREEN="\033[1;32m"
WHITE="\033[1;37m"
RESET="\033[0m"

# ---------- Loading Screen ----------
loading() {
    clear
    echo -e "${PURPLE}"
    echo "=============================================="
    echo "            NightLord Tools Loader"
    echo "=============================================="
    echo -e "${RESET}"

    width=40

    for ((i=0; i<=width; i++)); do
        percent=$((i*100/width))

        filled=$(printf "%${i}s" "" | tr ' ' '█')

        printf "\r${WHITE}Loading ${PURPLE}[${GREEN}%-40s${PURPLE}] ${WHITE}%3d%%${RESET}" "$filled" "$percent"

        sleep 0.05
    done

    echo
    sleep 0.5
    clear
}

# Show loading animation once
loading

# ---------- Main Menu ----------
while true; do
    clear

    echo -e "${PURPLE}"
    echo "=================================================="
    echo " _   _ _       _     _   _                     _ "
    echo "| \\ | (_)     | |   | | | |                   | |"
    echo "|  \\| |_  __ _| |__ | |_| |    ___  _ __   ___| |"
    echo "| . \` | |/ _\` | '_ \\| __| |   / _ \\| '_ \\ / _ \\ |"
    echo "| |\\  | | (_| | | | | |_| |__| (_) | | | |  __/_|"
    echo "|_| \\_|_|\\__, |_| |_|\\__|_____\\___/|_| |_|\\___(_)"
    echo "          __/ |                                  "
    echo "         |___/                                   "
    echo
    echo "               N I G H T L O R D   T O O L S"
    echo "=================================================="
    echo -e "${RESET}"

    echo -e "${PURPLE}1) 24/7${RESET}"
    echo -e "${PURPLE}2) Petro Install${RESET}"
    echo -e "${PURPLE}3) Run MC-CB${RESET}"
    echo -e "${PURPLE}4) Exit${RESET}"
    echo

    read -p "Select option: " option

    case "$option" in
        1)
            clear
            echo -e "${PURPLE}Launching 24/7...${RESET}"
            sleep 1
            curl -fsSL "https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/24-7" | python3
            echo
            read -p "Press Enter to return to menu..."
            ;;

        2)
            clear
            echo -e "${PURPLE}Launching Petro Install...${RESET}"
            sleep 1
            bash -c "$(curl -fsSL https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/Petroldectal%20Create)"
            echo
            read -p "Press Enter to return to menu..."
            ;;

        3)
            clear
            echo -e "${PURPLE}Starting MC-CB...${RESET}"
            sleep 1
            cd mc
            java -Xmx8196M -Xms8196M -jar Server.jar nogui
            echo
            read -p "Press Enter to return to menu..."
            ;;

        4)
            clear
            echo -e "${PURPLE}Thanks for using NightLord Tools!${RESET}"
            sleep 1
            break
            ;;

        *)
            echo
            echo -e "\033[1;31mInvalid option! Please try again.${RESET}"
            sleep 2
            ;;
    esac
done
