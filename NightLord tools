#!/bin/bash

# ==========================
# NIGHTLORD TOOLS v5.7 ULTIMATE
# ==========================

# Colors
PURPLE="\033[1;35m"
GREEN="\033[1;32m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
CYAN="\033[1;36m"
WHITE="\033[1;37m"
RESET="\033[0m"

# Paths
WORK_DIR="$(pwd)"
MC_DIR="$WORK_DIR/mc"
PLUGIN_DIR="$MC_DIR/plugins"
CONFIG_FILE="$HOME/.nightlord.conf"
VERSION="5.7 ULTIMATE"

# Load config
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
RAM=${RAM:-"8192M"}
JAVA_FLAGS=${JAVA_FLAGS:-"-Xms${RAM} -Xmx${RAM}"}

# ==========================
# HEADER (GUI PANEL)
# ==========================
header() {
clear
echo -e "${PURPLE}"
echo "╔══════════════════════════════════════════════╗"
echo "║        🌙 NIGHTLORD CONTROL PANEL v5.7       ║"
echo "║        Minecraft Hosting & Manager          ║"
echo "╚══════════════════════════════════════════════╝"
echo -e "${RESET}"

echo -e "${CYAN}RAM: ${GREEN}$RAM${RESET} | ${CYAN}MC_DIR: ${GREEN}$MC_DIR${RESET}"
echo -e "${CYAN}Version: ${GREEN}$VERSION${RESET}"
echo
}

# ==========================
# LOADING ANIMATION
# ==========================
loading() {
echo -ne "${YELLOW}Loading System"
for i in {1..12}; do
echo -ne "."
sleep 0.15
done
echo -e " ${GREEN}Ready!${RESET}"
sleep 0.5
}

# ==========================
# PAUSE
# ==========================
pause() {
echo
read -p "Press Enter..."
}

# ==========================
# RAM DETECT
# ==========================
detect_ram() {
TOTAL=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo)
USE=$((TOTAL-512))
[ "$USE" -lt 512 ] && USE=512
RAM="${USE}M"
JAVA_FLAGS="-Xms${RAM} -Xmx${RAM}"
echo "RAM=\"$RAM\"" > "$CONFIG_FILE"
}

# ==========================
# PAPER VERSION SELECTOR
# ==========================
version_selector() {
while true; do
header
echo -e "${PURPLE}══ SELECT PAPER MC VERSION ══${RESET}"
echo "1) Paper 1.21.11 (Latest Stable) 🔥"
echo "2) Paper 1.21.4"
echo "3) Paper 1.21.1"
echo "4) Paper 1.20.4"
echo "5) Paper 1.19.4"
echo "6) Paper 1.18.2"
echo "7) Paper 1.16.5"
echo "8) Paper 1.12.2 (Legacy)"
echo "9) Custom URL"
echo "10) Back"
echo
read -p "Select Version: " v_choice

case $v_choice in
1)
    DOWNLOAD_URL="https://fill-data.papermc.io/v1/objects/e708e8c132dc143ffd73528cccb9532e2eb17628b1a0eee74469bf466c7003f8/paper-1.21.11-116.jar"
    break
    ;;
2)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.21.4/builds/95/downloads/paper-1.21.4-95.jar"
    break
    ;;
3)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.21.1/builds/126/downloads/paper-1.21.1-126.jar"
    break
    ;;
4)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.20.4/builds/496/downloads/paper-1.20.4-496.jar"
    break
    ;;
5)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.19.4/builds/550/downloads/paper-1.19.4-550.jar"
    break
    ;;
6)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.18.2/builds/388/downloads/paper-1.18.2-388.jar"
    break
    ;;
7)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.16.5/builds/794/downloads/paper-1.16.5-794.jar"
    break
    ;;
8)
    DOWNLOAD_URL="https://api.papermc.io/v2/projects/paper/versions/1.12.2/builds/1618/downloads/paper-1.12.2-1618.jar"
    break
    ;;
9)
    read -p "Paste direct Paper jar download URL: " DOWNLOAD_URL
    if [ -z "$DOWNLOAD_URL" ]; then
        echo -e "${RED}Invalid URL!${RESET}"
        sleep 1
    else
        break
    fi
    ;;
10)
    return 1
    ;;
*)
    echo -e "${RED}Invalid Option!${RESET}"
    sleep 1
    ;;
esac
done
return 0
}

# ==========================
# SERVER SETUP
# ==========================
setup_server() {
version_selector
if [ $? -eq 1 ]; then
    return
fi

header
loading

mkdir -p "$MC_DIR"
cd "$MC_DIR" || return

echo -e "${CYAN}Downloading Selected Paper Server...${RESET}"
curl -L -o server.jar "$DOWNLOAD_URL"

if [ $? -ne 0 ] || [ ! -s server.jar ]; then
    echo -e "${RED}❌ Download failed! Please check your internet or URL.${RESET}"
    rm -f server.jar
    pause
    return
fi

echo "eula=true" > eula.txt
mkdir -p plugins

echo -e "${GREEN}✔ Server Setup Completed successfully!${RESET}"
pause
}

# ==========================
# RUN SERVER
# ==========================
run_server() {
header
loading

cd "$MC_DIR" || return

if [ ! -f server.jar ]; then
echo -e "${RED}Server not found! Run Setup first.${RESET}"
pause
return
fi

echo -e "${GREEN}Starting Server...${RESET}"
java $JAVA_FLAGS -jar server.jar nogui
pause
}

# ==========================
# PLUGIN MANAGER
# ==========================
plugins() {
while true; do
header

mkdir -p "$PLUGIN_DIR"
cd "$PLUGIN_DIR"

echo -e "${CYAN}══ Plugin Manager ══${RESET}"
echo "1) ViaVersion"
echo "2) ViaBackwards"
echo "3) SkinsRestorer"
echo "4) Connect"
echo "5) Install All"
echo "6) Back"

read -p "Select: " p

case $p in
1)
curl -L -o ViaVersion.jar https://github.com/ViaVersion/ViaVersion/releases/download/5.10.0/ViaVersion-5.10.0.jar
;;
2)
curl -L -o ViaBackwards.jar https://github.com/ViaVersion/ViaBackwards/releases/download/5.10.0/ViaBackwards-5.10.0.jar
;;
3)
curl -L -o SkinsRestorer.jar https://github.com/SkinsRestorer/SkinsRestorer/releases/download/15.12.0/SkinsRestorer.jar
;;
4)
curl -L -o Connect.jar https://github.com/minekube/connect-java/releases/latest/download/connect-spigot.jar
;;
5)
plugins_all
;;
6)
break
;;
esac
done
}

plugins_all() {
curl -L -o ViaVersion.jar https://github.com/ViaVersion/ViaVersion/releases/download/5.10.0/ViaVersion-5.10.0.jar
curl -L -o ViaBackwards.jar https://github.com/ViaVersion/ViaBackwards/releases/download/5.10.0/ViaBackwards-5.10.0.jar
curl -L -o SkinsRestorer.jar https://github.com/SkinsRestorer/SkinsRestorer/releases/download/15.12.0/SkinsRestorer.jar
curl -L -o Connect.jar https://github.com/minekube/connect-java/releases/latest/download/connect-spigot.jar

echo -e "${GREEN}All Plugins Installed!${RESET}"
pause
}

# ==========================
# SETTINGS
# ==========================
settings() {
while true; do
header

echo "1) Auto RAM Detect"
echo "2) Change RAM"
echo "3) Show Config"
echo "4) Back"

read -p "Select: " s

case $s in
1)
detect_ram
echo -e "${GREEN}Auto RAM Enabled${RESET}"
pause
;;
2)
read -p "Enter RAM: " RAM
echo "RAM=\"$RAM\"" > "$CONFIG_FILE"
JAVA_FLAGS="-Xms${RAM} -Xmx${RAM}"
pause
;;
3)
echo "RAM: $RAM"
echo "JAVA: $JAVA_FLAGS"
pause
;;
4)
break
;;
esac
done
}

# ==========================
# 24/7 HOST (GITHUB SCRIPT)
# ==========================
host_24_7() {
header
loading

echo -e "${GREEN}Starting 24/7 GitHub Host...${RESET}"
sleep 1

while true; do
curl -fsSL "https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/24-7" | python3
echo -e "${YELLOW}Restarting 24/7 Script...${RESET}"
sleep 3
done
}

# ==========================
# MAIN MENU UI
# ==========================
while true; do
header
loading

echo -e "${PURPLE}══ MAIN MENU ══${RESET}"
echo "1) 🚀 Setup Server"
echo "2) 🎮 Run Server"
echo "3) 🔌 Plugin Manager"
echo "4) ⚙️ Settings"
echo "5) 🔄 24/7 Host"
echo "6) ❌ Exit"

read -p "Choose: " c

case $c in
1) setup_server ;;
2) run_server ;;
3) plugins ;;
4) settings ;;
5) host_24_7 ;;
6) exit 0 ;;
*) echo "Invalid"; sleep 1 ;;
esac
done

