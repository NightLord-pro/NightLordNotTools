#!/bin/bash

# ==========================
# NightLord Tools v2.1
# FIXED STABLE EDITION
# ==========================

# Colors
PURPLE="\033[1;35m"
GREEN="\033[1;32m"
WHITE="\033[1;37m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
CYAN="\033[1;36m"
RESET="\033[0m"

SCRIPT_DIR="$(pwd)"
CONFIG_FILE="$HOME/.nightlord.conf"

# Default RAM
RAM="8192M"
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

JAVA_FLAGS="-Xms${RAM} -Xmx${RAM}"
VERSION="2.1"

# ==========================
banner() {
clear
echo -e "${PURPLE}"
echo "=============================================="
echo "        NIGHTLORD TOOLS v$VERSION"
echo "=============================================="
echo -e "${RESET}"
}

pause(){ read -p "Press Enter..." }

check_java(){
command -v java >/dev/null 2>&1 || {
echo -e "${RED}Java not installed!${RESET}"
return 1
}
}

# ==========================
# LOADING
# ==========================
loading(){
banner
echo -e "${CYAN}Starting NightLord...${RESET}"
sleep 1
clear
}

loading

# ==========================
# MC START
# ==========================
start_server(){
check_java || { pause; return; }

MC_DIR="$SCRIPT_DIR/mc"

if [ ! -d "$MC_DIR" ]; then
echo -e "${RED}MC folder missing!${RESET}"
pause
return
fi

cd "$MC_DIR" || return

[ ! -f server.jar ] && {
echo -e "${RED}server.jar missing!${RESET}"
pause
return
}

echo "eula=true" > eula.txt

java $JAVA_FLAGS -jar server.jar nogui
pause
}

# ==========================
setup_server(){
mkdir -p mc
cd mc || return

echo -e "${CYAN}Downloading Paper...${RESET}"

curl -L -o server.jar \
"https://fill-data.papermc.io/v1/objects/8de7c52c3b02403503d16fac58003f1efef7dd7a0256786843927fa92ee57f1e/paper-1.21.8-60.jar"

echo "eula=true" > eula.txt

cd ..
echo -e "${GREEN}Setup Done!${RESET}"
pause
}

# ==========================
plugin_menu(){
while true; do
banner
echo "PLUGIN MANAGER"
echo "1 ViaVersion"
echo "2 ViaBackwards"
echo "3 SkinsRestorer"
echo "4 Connect"
echo "5 All"
echo "6 Back"

read -p ">> " p

PLUGIN_DIR="$SCRIPT_DIR/mc/plugins"
mkdir -p "$PLUGIN_DIR"
cd "$PLUGIN_DIR" || return

case $p in
1) curl -L -o ViaVersion.jar https://github.com/ViaVersion/ViaVersion/releases/download/5.10.0/ViaVersion-5.10.0.jar ;;
2) curl -L -o ViaBackwards.jar https://github.com/ViaVersion/ViaBackwards/releases/download/5.10.0/ViaBackwards-5.10.0.jar ;;
3) curl -L -o SkinsRestorer.jar https://github.com/SkinsRestorer/SkinsRestorer/releases/download/15.12.0/SkinsRestorer.jar ;;
4) curl -L -o Connect.jar https://github.com/minekube/connect-java/releases/download/latest/connect-spigot.jar ;;
5)
curl -L -o ViaVersion.jar https://github.com/ViaVersion/ViaVersion/releases/download/5.10.0/ViaVersion-5.10.0.jar
curl -L -o ViaBackwards.jar https://github.com/ViaVersion/ViaBackwards/releases/download/5.10.0/ViaBackwards-5.10.0.jar
curl -L -o SkinsRestorer.jar https://github.com/SkinsRestorer/SkinsRestorer/releases/download/15.12.0/SkinsRestorer.jar
curl -L -o Connect.jar https://github.com/minekube/connect-java/releases/download/latest/connect-spigot.jar
;;
6) break ;;
*) echo "Invalid"; sleep 1 ;;
esac

done
}

# ==========================
settings_menu(){
while true; do
banner
echo "SETTINGS"
echo "RAM: $RAM"
echo "1 Change RAM"
echo "2 Reset"
echo "3 Back"

read -p ">> " s

case $s in
1)
read -p "Enter RAM (e.g. 4096M): " RAM
JAVA_FLAGS="-Xms${RAM} -Xmx${RAM}"
;;
2)
RAM="8192M"
JAVA_FLAGS="-Xms8192M -Xmx8192M"
;;
3) break ;;
esac

done
}

# ==========================
MAIN MENU
# ==========================
while true; do
banner

echo "1 24/7"
echo "2 Petro Install"
echo "3 MC-CB"
echo "4 Settings"
echo "5 Update"
echo "6 Exit"

read -p "Select: " opt

case $opt in
1)
curl -fsSL https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/24-7 | python3
pause
;;
2)
bash -c "$(curl -fsSL https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/Petroldectal%20Create)"
pause
;;
3)
while true; do
banner
echo "MC-CB MENU"
echo "1 Run Server"
echo "2 Setup Server"
echo "3 Plugin Manager"
echo "4 Back"

read -p ">> " m

case $m in
1) start_server ;;
2) setup_server ;;
3) plugin_menu ;;
4) break ;;
esac
done
;;
4) settings_menu ;;
5) echo "Update coming soon"; pause ;;
6) exit 0 ;;
*) echo "Invalid"; sleep 1 ;;
esac

done
