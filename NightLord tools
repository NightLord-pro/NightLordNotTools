#!/bin/bash

# ==========================
# NightLord Tools
# ==========================

# Colors
PURPLE="\033[1;35m"
GREEN="\033[1;32m"
WHITE="\033[1;37m"
RED="\033[1;31m"
RESET="\033[0m"

# ---------- Loading Screen ----------
loading() {
    clear
    echo -e "${PURPLE}"
    echo "=============================================="
    echo "            NightLord Tools Loader"
    echo "=============================================="
    echo -e "${RESET}"

    width=40

    for ((i=0; i<=width; i++)); do
        percent=$((i*100/width))
        filled=$(printf "%${i}s" "" | tr ' ' 'тЦИ')

        printf "\r${WHITE}Loading ${PURPLE}[${GREEN}%-40s${PURPLE}] ${WHITE}%3d%%${RESET}" "$filled" "$percent"
        sleep 0.05
    done

    echo
    sleep 0.5
    clear
}

# Show loading animation
loading

# ---------- Main Menu ----------
while true; do
    clear

    echo -e "${PURPLE}"
    echo "=================================================="
    echo "тЦСтЦИтЦДтФАтЦСтЦИ тЦАтЦИтЦА тЦСтЦИтЦАтЦАтЦИ тЦСтЦИтФАтЦСтЦИ тЦАтЦАтЦИтЦАтЦА тЦСтЦИтФАтФАтФА тЦСтЦИтЦАтЦАтЦАтЦИ тЦСтЦИтЦАтЦАтЦИ тЦСтЦИтЦАтЦАтЦД"
    echo "тЦСтЦИтЦСтЦИтЦСтЦИ тЦСтЦИтФА тЦСтЦИтФАтЦДтЦД тЦСтЦИтЦАтЦАтЦИ тФАтЦСтЦИтФАтФА тЦСтЦИтФАтФАтФА тЦСтЦИтФАтФАтЦСтЦИ тЦСтЦИтЦДтЦДтЦА тЦСтЦИтФАтЦСтЦИ"
    echo "тЦСтЦИтФАтФАтЦАтЦИ тЦДтЦИтЦД тЦСтЦИтЦДтЦДтЦИ тЦСтЦИтФАтЦСтЦИ тФАтЦСтЦИтФАтФА тЦСтЦИтЦДтЦДтЦИ тЦСтЦИтЦДтЦДтЦДтЦИ тЦСтЦИтФАтЦСтЦИ тЦСтЦИтЦДтЦДтЦА"
    echo
    echo "                  ЁЭЧбЁЭЧЬЁЭЧЪЁЭЧЫЁЭЧзЁЭЧЯЁЭЧвЁЭЧеЁЭЧЧ"
    echo "                     TOOLS"
    echo "=================================================="
    echo -e "${RESET}"

    echo -e "${PURPLE}1) 24/7${RESET}"
    echo -e "${PURPLE}2) Petro Install${RESET}"
    echo -e "${PURPLE}3) Run MC-CB${RESET}"
    echo -e "${PURPLE}4) Setup MC-CB${RESET}"
    echo -e "${PURPLE}5) Plugins${RESET}"
    echo -e "${PURPLE}6) Exit${RESET}"
    echo

    read -p "Select option: " option

    case "$option" in

        1)
            clear
            echo -e "${PURPLE}Launching 24/7...${RESET}"
            sleep 1
            curl -fsSL "https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/24-7" | python3
            echo
            read -p "Press Enter to return to menu..."
            ;;

        2)
            clear
            echo -e "${PURPLE}Launching Petro Install...${RESET}"
            sleep 1
            bash -c "$(curl -fsSL https://raw.githubusercontent.com/NightLord-pro/NightLordNotTools/refs/heads/main/Petroldectal%20Create)"
            echo
            read -p "Press Enter to return to menu..."
            ;;

        3)
            clear
            echo -e "${PURPLE}Starting MC-CB...${RESET}"
            sleep 1

            cd mc || {
                echo -e "${RED}Folder 'mc' not found!${RESET}"
                echo
                read -p "Press Enter to return to menu..."
                continue
            }

            java -Xmx8196M -Xms8196M -jar server.jar nogui

            echo
            read -p "Press Enter to return to menu..."
            ;;

        4)
            clear
            echo -e "${PURPLE}Setting up MC-CB...${RESET}"
            sleep 1

            mkdir -p mc
            cd mc || exit

            echo -e "${WHITE}Downloading Paper 1.21.8...${RESET}"

            curl -L -o server.jar "https://fill-data.papermc.io/v1/objects/8de7c52c3b02403503d16fac58003f1efef7dd7a0256786843927fa92ee57f1e/paper-1.21.8-60.jar"

            if [ $? -eq 0 ]; then
                echo
                echo -e "${GREEN}тЬУ MC-CB setup completed successfully!${RESET}"
                echo -e "${GREEN}Server saved as: mc/server.jar${RESET}"
            else
                echo
                echo -e "${RED}тЬЧ Failed to download server.jar!${RESET}"
            fi

            echo
            read -p "Press Enter to return to menu..."
            ;;

         5)
            clear
            echo -e "${PURPLE}Installing Plugins...${RESET}"
            sleep 1

            if [ ! -d "mc/plugins" ]; then
                echo -e "${RED}Folder 'mc/plugins' not found!${RESET}"
                echo -e "${RED}Please start the server once to generate the plugins folder.${RESET}"
                echo
                read -p "Press Enter to return to menu..."
                continue
            fi

            cd mc/plugins || continue

            echo -e "${WHITE}Downloading ViaVersion...${RESET}"
            curl -L -o ViaVersion.jar "https://github.com/ViaVersion/ViaVersion/releases/download/5.10.0/ViaVersion-5.10.0.jar"

            echo -e "${WHITE}Downloading ViaBackwards...${RESET}"
            curl -L -o ViaBackwards.jar "https://github.com/ViaVersion/ViaBackwards/releases/download/5.10.0/ViaBackwards-5.10.0.jar"

            echo -e "${WHITE}Downloading SkinsRestorer...${RESET}"
            curl -L -o SkinsRestorer.jar "https://github.com/SkinsRestorer/SkinsRestorer/releases/download/15.12.0/SkinsRestorer.jar"

            echo -e "${WHITE}Downloading Connect...${RESET}"
            curl -L -o Connect.jar "https://github.com/minekube/connect-java/releases/download/latest/connect-spigot.jar"

            echo
            echo -e "${GREEN}тЬУ All plugins installed successfully!${RESET}"
            echo
            read -p "Press Enter to return to menu..."
            ;;

        6)
            clear
            echo -e "${PURPLE}Thanks for using NightLord Tools!${RESET}"
            sleep 1
            break
            ;;

        *)
            echo
            echo -e "${RED}Invalid option! Please try again.${RESET}"
            sleep 2
            ;;
    esac
done
